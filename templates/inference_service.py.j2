# FastAPI 路由
# ═════════════════════════════════════════════════════════════════════════════

MODELS: Dict[str, Any] = {}
MODEL_PATHS = {{ models_config | tojson(indent=4) }}
STFPM_DETECTOR: MultiSTFPMDetector = None
TEMPLATE_IMAGE: np.ndarray = None  # 预加载的模板图
TEMPLATE_ANNOTATIONS: List[Dict[str, Any]] = []  # 模板图片的标注框信息


class PredictROIResponse(BaseModel):
    """ROI检测响应，返回每个标注框的详细检测结果"""
    results: List[Dict[str, Any]]
    processing_time: float
    total_detections: int
    anomaly_count: int

def load_models():
    """加载所有模型和模板图"""
    global STFPM_DETECTOR, MODELS, TEMPLATE_IMAGE, TEMPLATE_ANNOTATIONS
    
    # 初始化STFPM检测器
    # 模型路径格式: {label: path, label_type: type}
    # 我们需要提取所有模型目录
    model_dirs = set()
    for key, path in MODEL_PATHS.items():
        if not key.endswith('_type') and key != '_labels' and key != '_model_type':
            model_dirs.add(path)
    
    if model_dirs:
        # 使用第一个模型目录的父目录作为基础目录
        base_dir = Path(list(model_dirs)[0]).parent
        STFPM_DETECTOR = MultiSTFPMDetector(base_dir)
        MODELS = {cat: {'loaded': True} for cat in STFPM_DETECTOR.get_loaded_categories()}
        logger.info(f"Loaded {len(MODELS)} models: {list(MODELS.keys())}")
        
        # 优先从 annotations.json 加载模板图片（选择 angle 最接近 0 且没有反转的图片）
        annotations_path = Path("{{ annotations_path }}") if "{{ annotations_path }}" else None
        
        if annotations_path and annotations_path.exists():
            template_path, template_anns = select_best_template_from_annotations(str(annotations_path))
            if template_path:
                TEMPLATE_IMAGE = cv2.imread(template_path)
                TEMPLATE_ANNOTATIONS = template_anns
                if TEMPLATE_IMAGE is not None:
                    logger.info(f"Loaded template image from annotations: {template_path}, "
                               f"with {len(TEMPLATE_ANNOTATIONS)} annotations")
        
        # 如果无法从 annotations 加载，则回退到从模型目录查找 template.jpg
        if TEMPLATE_IMAGE is None:
            for model_dir in model_dirs:
                template_path = Path(model_dir) / "template.jpg"
                if template_path.exists():
                    TEMPLATE_IMAGE = cv2.imread(str(template_path))
                    if TEMPLATE_IMAGE is not None:
                        logger.info(f"Loaded template image from: {template_path}")
                        break
        
        if TEMPLATE_IMAGE is None:
            logger.warning("No template image found")
    else:
        logger.warning("No model directories found")

@app.on_event("startup")
async def startup_event():
    load_models()

@app.get("/health")
async def health_check():
    loaded = list(MODELS.keys()) if MODELS else []
    return {
        "status": "healthy",
        "service_id": "{{ service_id }}",
        "project_id": "{{ project_id }}",
        "task_uuid": "{{ task_uuid }}",
        "loaded_models": loaded,
        "total_models": len(MODELS)
    }

@app.get("/models")
async def list_models():
    return {
        "models": list(MODELS.keys()),
        "loaded": list(MODELS.keys())
    }


@app.post("/predict", response_model=PredictROIResponse)
async def predict(
    file: UploadFile = File(None),
    image: str = Form(None)
):
    """
    统一的预测接口，支持文件上传和base64两种方式
    
    方式1（文件上传）:
        POST /predict
        Content-Type: multipart/form-data
        Body: file=<图片文件>
    
    方式2（Base64）:
        POST /predict
        Content-Type: application/json
        Body: {"image": "<base64字符串>"}
    
    自动使用模板图片的标注信息进行ROI检测
    返回每个标注框的详细检测结果
    """
    start_time = time.time()
    request_id = f"{int(start_time * 1000)}"
    
    logger.info(f"[{request_id}] ========== PREDICTION REQUEST ==========")
    
    try:
        # 获取图片数据
        image_data = None
        input_type = None
        
        if file is not None:
            input_type = "file"
            logger.info(f"[{request_id}] Input type: file upload")
            logger.info(f"[{request_id}] Filename: {file.filename}")
            contents = await file.read()
            logger.info(f"[{request_id}] File size: {len(contents)} bytes")
            nparr = np.frombuffer(contents, np.uint8)
            image_data = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
        elif image is not None:
            input_type = "base64"
            logger.info(f"[{request_id}] Input type: base64")
            image_b64 = image
            if "," in image_b64:
                image_b64 = image_b64.split(",")[1]
            img_data = base64.b64decode(image_b64)
            logger.info(f"[{request_id}] Base64 decoded size: {len(img_data)} bytes")
            nparr = np.frombuffer(img_data, np.uint8)
            image_data = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
        else:
            logger.error(f"[{request_id}] No image provided")
            raise HTTPException(status_code=400, detail="No image provided")
        
        if image_data is None:
            logger.error(f"[{request_id}] Failed to decode image")
            raise HTTPException(status_code=400, detail="Invalid image")
        
        logger.info(f"[{request_id}] Image decoded successfully: shape={image_data.shape}")
        
        if STFPM_DETECTOR is None:
            logger.error(f"[{request_id}] Models not loaded")
            raise HTTPException(status_code=500, detail="Models not loaded")
        
        if TEMPLATE_IMAGE is None:
            logger.error(f"[{request_id}] Template image not loaded")
            raise HTTPException(status_code=500, detail="Template image not loaded")
        
        logger.info(f"[{request_id}] Template image: shape={TEMPLATE_IMAGE.shape}")
        
        annotations_list = TEMPLATE_ANNOTATIONS
        logger.info(f"[{request_id}] Template annotations count: {len(annotations_list)}")
        
        if not annotations_list:
            logger.error(f"[{request_id}] No template annotations available")
            raise HTTPException(status_code=400, detail="No template annotations available")
        
        logger.info(f"[{request_id}] Starting ROI detection...")
        roi_results = detect_with_annotations(
            STFPM_DETECTOR, 
            image_data, 
            TEMPLATE_IMAGE, 
            annotations_list,
            request_id
        )
        
        processing_time = time.time() - start_time
        anomaly_count = sum(1 for r in roi_results if r.get('is_anomaly', False))
        
        # 打印详细预测结果
        logger.info(f"[{request_id}] ========== PREDICTION RESULTS ==========")
        logger.info(f"[{request_id}] Total ROIs: {len(roi_results)}")
        logger.info(f"[{request_id}] Anomalies detected: {anomaly_count}")
        logger.info(f"[{request_id}] Processing time: {processing_time:.3f}s")
        logger.info(f"[{request_id}] ----------------------------------------")
        
        for i, r in enumerate(roi_results):
            status = "ANOMALY" if r.get('is_anomaly') else "NORMAL"
            category = r.get('category', 'unknown')
            score = r.get('anomaly_score', 0)
            threshold = r.get('threshold', 0)
            error = r.get('error', 0)
            bbox = r.get('bbox', [0,0,0,0])
            strategy = r.get('alignment_strategy', 'unknown')
            
            logger.info(f"[{request_id}] ROI {i+1:2d}: {category:8s} | {status:7s} | "
                       f"score={score:.3f} | threshold={threshold:.3f} | error={error:.3f} | "
                       f"bbox={bbox} | strategy={strategy}")
        
        logger.info(f"[{request_id}] ========== REQUEST COMPLETED ==========")
        
        return PredictROIResponse(
            results=roi_results, 
            processing_time=processing_time,
            total_detections=len(roi_results),
            anomaly_count=anomaly_count
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"[{request_id}] Prediction error: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


def signal_handler(sig, frame):
    logger.info("Shutting down inference service...")
    sys.exit(0)

signal.signal(signal.SIGINT, signal_handler)
